@{
    ViewData["Title"] = "Home Page";
}

<div class="d-flex flex-column align-items-center text-center mt-5">
    <div class="col-md-3 col-lg-3 col-xl-3 py-4 bg-white rounded-3" style="max-width: 350px;">
        <img src="~/images/welcome-icon.png" alt="Logo">
        <h6 class="mt-2 mb-5">¡Bienvenido, Miguel!</h6>
        <p class="small">Su cuenta en el aplicativo X está activada.</p>
        <p class="small">Ya puede iniciar sesión .</p>

        <div class="d-grid" style="padding: 3rem 0rem 0rem;justify-items: center;">
            <a asp-controller="Auth" asp-action="Login" class="btn btn-primary bg-violet" style="width: 260px;font-size: 14px;">Iniciar Sesión</a>
        </div>
    </div>
</div>